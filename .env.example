# Copy to .env.local and uncomment overrides as needed.
# See docs/configuration.md for details.

# Ollama
OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llava:7b

# ComfyUI
COMFYUI_HOST=http://localhost:8188
COMFYUI_WS_URL=ws://localhost:8188/ws
# COMFYUI_MEMORY_MODE=--cpu

# Flux model filenames (defaults shown)
# FLUX_CLIP_L=clip_l.safetensors
# FLUX_T5=t5xxl_fp8_e4m3fn.safetensors
# FLUX_VAE=ae.safetensors

# Upload / storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Upload compression (Sharp)
MAX_IMAGE_WIDTH=1024
MAX_IMAGE_HEIGHT=1024
JPEG_QUALITY=85
PNG_QUALITY=90
WEBP_QUALITY=85
