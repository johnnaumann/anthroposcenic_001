{
  "name": "anthroposcenic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"ollama,next,ready\" -c \"yellow,cyan,green\" \"npm run dev:ollama\" \"npm run dev:next\" \"npm run dev:open\"",
    "dev:next": "next dev",
    "dev:ollama": "bash scripts/start-ollama.sh",
    "dev:open": "wait-on http://localhost:3000 http://localhost:11434/api/tags && bash scripts/open-browser.sh",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "setup": "npm run setup:ollama && npm run setup:comfyui",
    "setup:ollama": "bash scripts/pull-ollama-model.sh",
    "setup:comfyui": "bash scripts/setup-comfyui.sh && bash scripts/download-flux.sh",
    "comfyui:run": "bash scripts/run-comfyui.sh",
    "comfyui:sd": "bash scripts/download-all-models.sh && bash scripts/download-upscale-model.sh && bash scripts/download-controlnet-tile.sh"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.5.1",
    "lucide-react": "^0.427.0",
    "next": "^14.2.5",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.11.0",
    "sharp": "^0.33.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^10.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "wait-on": "^9.0.3",
    "postcss": "^8.4.40",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.5.4"
  }
}
